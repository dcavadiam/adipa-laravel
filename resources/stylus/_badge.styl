.badge
    position absolute
    top 1rem
    right 1rem
    padding 0.375rem 1rem
    border-radius 9999px
    font-size 0.8rem
    font-weight 600
    border 1px solid rgba(255, 255, 255, 0.3)
    color $white
    display flex
    align-items center
    gap 0.375rem

    &__icon
        width 20px
        height 20px

    &--online
        background rgba(255, 169, 39, 0.7)

    &--live
        background rgba(255, 1, 124, 0.7)

    &--presencial
        background rgba(44, 183, 255, 0.7)