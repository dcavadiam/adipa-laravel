.filter-pill
    padding 0.5rem 1.25rem
    border-radius 9999px
    font-size 0.95rem
    font-weight 500
    border 1px solid #d1d5db
    background $white
    color #374151
    cursor pointer
    transition all 0.2s ease

    &:hover:not(&--active)
        border-color $primary
        color $primary
        background rgba(112, 78, 253, 0.05)

    &--active
        background $primary
        color $white
        border-color $primary
        box-shadow 0 2px 8px rgba(112, 78, 253, 0.3)