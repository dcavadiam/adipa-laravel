.contact
    margin-bottom 3rem
    padding 0 $padding-global

    &__container
        max-width $container-max-width
        margin 0 auto
        background $dark
        color $white
        padding 3rem
        border-radius 1rem
        box-shadow 0 4px 20px rgba(3, 27, 78, 0.15)

    &__title
        font-size 1.5rem
        font-weight 700
        text-align center
        margin-bottom 1.5rem

    &__success
        display none
        margin-bottom 1rem
        padding 1rem
        border-radius 0.5rem
        background #22c55e
        color $white
        text-align center
        font-weight 500

        &.is-visible
            display block

    &__form
        display flex
        flex-direction column
        gap 1rem

    &__row
        display flex
        flex-direction column
        gap 1rem

    &__field
        display flex
        flex-direction column
        gap 0.5rem
        width 100%

    &__label
        font-size 1rem
        font-weight 600

    &__input
        width 100%
        padding 0.625rem
        border-radius 0.375rem
        border 1px solid #d1d5db
        background $white
        color #111
        font-family $font-body
        font-size 0.95rem
        transition all 0.2s ease
        outline none

        &:focus
            border-color $primary
            box-shadow 0 0 0 2px rgba(112, 78, 253, 0.2)

        &--textarea
            resize vertical
            min-height 100px

        &--error
            border-color #ef4444

    &__error
        display none
        color #ef4444
        font-size 0.8rem

        &.is-visible
            display block

    &__btn
        width 100%
        padding 0.625rem
        border-radius 0.375rem
        background $secondary
        color $white
        font-weight 500
        font-size 0.95rem
        margin-top 1rem
        transition all 0.3s ease
        border none
        cursor pointer

        &:hover
            background rgba(44, 183, 255, 0.8)

@media (min-width: 768px)
    .contact__row
        flex-direction row